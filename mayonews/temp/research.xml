		<link>https://newsnetwork.mayoclinic.org/discussion/connect-with-leading-experts-at-mayo-clinics-ai-research-summit/
		
		<dc:creator><!--[CDATA[krisschanilec1]]--></dc:creator>
		<pubdate>Fri, 13 Feb 2026 13:32:06 +0000</pubdate>
				<category><!--[CDATA[AI and Digital Health]]--></category>
