		<title>Mayo Clinic study finds bariatric surgery associated with greater long-term heart&nbsp;risk reduction than weight-loss medications&nbsp;</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-study-finds-bariatric-surgery-associated-with-greater-long-term-heart-risk-reduction-than-weight-loss-medications/</link>
		
		<dc:creator><![CDATA[Chloe Corey]]></dc:creator>
		<pubDate>Tue, 28 Apr 2026 16:39:48 +0000</pubDate>
				<category><![CDATA[Cardiovascular]]></category>
		<category><![CDATA[Featured News]]></category>
		<category><![CDATA[Minnesota]]></category>
		<category><![CDATA[News Releases]]></category>
