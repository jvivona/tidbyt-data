		<title>Vitamin D linked to immune response to gut microbiome in inflammatory bowel disease</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/vitamin-d-linked-to-immune-response-to-gut-microbiome-in-inflammatory-bowel-disease/</link>
		
		<dc:creator><![CDATA[mbroadfoot]]></dc:creator>
