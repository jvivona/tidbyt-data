		<title>Mayo Clinic expert highlights improved survival in muscle-invasive bladder cancer and kidney cancer</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-expert-highlights-improved-survival-in-muscle-invasive-bladder-cancer-and-kidney-cancer/</link>
		
		<dc:creator><![CDATA[brittanycordeiro]]></dc:creator>
		<pubDate>Fri, 27 Feb 2026 15:21:52 +0000</pubDate>
				<category><![CDATA[Cancer]]></category>
		<category><![CDATA[Featured News]]></category>
