		<title>Robotic-assisted bronchoscopy study of more than 2,000 lung lesions suggests safer, faster path to diagnosing lung cancer (VIDEO)</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/video-robotic-assisted-bronchoscopy-study-of-more-than-2000-lung-lesions-suggests-safer-faster-path-to-diagnosing-lung-cancer/</link>
		
		<dc:creator><![CDATA[Alison Satake]]></dc:creator>
		<pubDate>Wed, 01 Apr 2026 13:00:00 +0000</pubDate>
				<category><![CDATA[Cancer]]></category>
		<category><![CDATA[Featured News]]></category>
		<category><![CDATA[Florida]]></category>
		<category><![CDATA[News Releases]]></category>
		<category><![CDATA[Research]]></category>
		<category><![CDATA[#Newsapp]]></category>
