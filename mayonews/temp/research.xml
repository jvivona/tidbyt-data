		<title>Brain may reinforce seizures during sleep, Mayo Clinic study suggests</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/brain-may-reinforce-seizures-during-sleep-mayo-clinic-study-suggests/
		
		<dc:creator><!--[CDATA[mbroadfoot]]--></dc:creator>
		<pubdate>Mon, 23 Feb 2026 15:00:00 +0000</pubdate>
				<category><!--[CDATA[Discovery Science]]--></category>
		<category><!--[CDATA[Featured News]]--></category>
		<category><!--[CDATA[Neurosciences]]--></category>
		<category><!--[CDATA[Research]]--></category>
		<category><!--[CDATA[#Newsapp]]--></category>
		<category><!--[CDATA[daily]]--></category>
