		<title>Mayo Clinic researchers link Parkinson&amp;#8217;s-related protein to faster Alzheimer&amp;#8217;s progression in women&nbsp;</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-researchers-link-parkinsons-related-protein-to-faster-alzheimers-progression-in-women/</link>
		
		<dc:creator><![CDATA[Susan Murphy]]></dc:creator>
