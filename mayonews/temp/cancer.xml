		<title>Mayo Clinic Q&amp;#038;A: Understanding myeloma treatment</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-qa-understanding-myeloma-treatment/</link>
		
		<dc:creator><![CDATA[pattymiller]]></dc:creator>
		<pubDate>Wed, 18 Mar 2026 12:33:54 +0000</pubDate>
