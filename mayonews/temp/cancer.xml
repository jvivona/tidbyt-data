		<title>New treatment works to improve hot flash symptoms in prostate cancer therapy</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/new-treatment-works-to-improve-hot-flash-symptoms-in-prostate-cancer-therapy/</link>
		
		<dc:creator><![CDATA[rebeccabromelkamp]]></dc:creator>
