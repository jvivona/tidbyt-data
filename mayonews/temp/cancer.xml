		<title>Mayo Clinic study demonstrates safety, feasibility of delivering chemotherapy at home</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-study-demonstrates-safety-feasibility-of-delivering-chemotherapy-at-home/</link>
		
		<dc:creator><![CDATA[selinameiners]]></dc:creator>
		<pubDate>Thu, 19 Mar 2026 20:09:37 +0000</pubDate>
				<category><![CDATA[Cancer]]></category>
		<category><![CDATA[Featured News]]></category>
		<category><![CDATA[Florida]]></category>
		<category><![CDATA[News Releases]]></category>
