		<title>When a healthy life meets an unexpected colon cancer diagnosis</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/when-a-healthy-life-meets-an-unexpected-colon-cancer-diagnosis/
		
		<dc:creator><!--[CDATA[connorbran]]--></dc:creator>
