		<title>Mayo Clinic Q&amp;#038;A: Treating colorectal cancer with surgery</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-qa-treating-colorectal-cancer-with-surgery/</link>
		
		<dc:creator><![CDATA[Chloe Corey]]></dc:creator>
		<pubDate>Thu, 05 Mar 2026 14:49:57 +0000</pubDate>
