		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-minute-mri-for-dense-breasts-what-to-know/
		
		<dc:creator><!--[CDATA[Deb Balzer]]--></dc:creator>
		<pubdate>Mon, 06 Oct 2025 12:27:00 +0000</pubdate>
				<category><!--[CDATA[Arizona]]--></category>
