		<title>Aging-related weight gain in women: It may start earlier in life than you think</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/aging-related-weight-gain-in-women-it-may-start-earlier-in-life-than-you-think/</link>
		
		<dc:creator><![CDATA[Sharon Theimer]]></dc:creator>
		<pubDate>Mon, 29 Dec 2025 14:15:00 +0000</pubDate>
