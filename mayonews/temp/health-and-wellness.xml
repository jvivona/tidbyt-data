		<title>Mayo Clinic Minute: Using combined therapy to treat obesity</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-minute-using-combined-therapy-to-treat-obesity/</link>
		
		<dc:creator><![CDATA[Jason Howland]]></dc:creator>
		<pubDate>Tue, 17 Feb 2026 13:53:02 +0000</pubDate>
