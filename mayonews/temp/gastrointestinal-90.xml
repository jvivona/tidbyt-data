		<title>Mayo Clinic Minute: AI advances help care teams find hard-to-see colon polyps</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-minute-ai-advances-help-care-teams-find-hard-to-see-colon-polyps/</link>
		
		<dc:creator><![CDATA[Alex Osiadacz]]></dc:creator>
		<pubDate>Wed, 18 Mar 2026 14:06:05 +0000</pubDate>
