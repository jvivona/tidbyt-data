		<title>Mayo Clinic researchers develop AI-ECG model to diagnose liver disease earlier</title>
		<link>https://newsnetwork.mayoclinic.org/discussion/mayo-clinic-researchers-develop-ai-ecg-model-to-diagnose-liver-disease-earlier/</link>
		
		<dc:creator><![CDATA[Alison Satake]]></dc:creator>
		<pubDate>Wed, 17 Dec 2025 10:05:00 +0000</pubDate>
				<category><![CDATA[Featured News]]></category>
		<category><![CDATA[Gastroenterology]]></category>
		<category><![CDATA[Minnesota]]></category>
		<category><![CDATA[News Releases]]></category>
		<category><![CDATA[Research]]></category>
		<category><![CDATA[#Newsapp]]></category>
		<category><![CDATA[daily]]></category>
